# Copy this file to .env and fill in your credentials (never commit .env).
# Values with special characters ({, [, *, etc.) MUST be single-quoted.

# ── KIE.ai API key ───────────────────────────────────────────────────────────
# Find and manage keys at: https://kie.ai/api-key
# Sent as a Bearer token on every request:
#   Authorization: Bearer $KIE_API_KEY
KIE_API_KEY=your_key_here

# ── Optional ─────────────────────────────────────────────────────────────────
# Override the base URL if KIE directs your workspace to a different host.
# KIE_BASE_URL=https://api.kie.ai
